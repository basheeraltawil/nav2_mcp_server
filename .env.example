# Nav2 MCP Server Configuration
# Copy this file to .env and adjust values as needed

# --- ROS 2 / DDS networking ---
# Must match the robot. TIAGo deployments commonly use a non-zero domain id.
ROS_DOMAIN_ID=0
# 0 when the server and the robot are on different machines (TIAGo on a
# separate host); 1 to restrict ROS 2 traffic to localhost (sim on this box).
ROS_LOCALHOST_ONLY=0

# --- Robot TF frames ---
# Defaults target PAL Robotics TIAGo on ROS 2 Humble.
MAP_FRAME=map
BASE_FRAME=base_footprint

# --- Nav2 docking ---
# opennav_docking only exists on ROS 2 Jazzy+. Keep this 0 on Humble (TIAGo);
# the dock/undock tools then return a clear FEATURE_NOT_SUPPORTED error.
ENABLE_DOCKING=0

# --- MCP transport ---
# Options: 'stdio' (default for local integration) | 'http' (containerized/network)
TRANSPORT_MODE=stdio

# HTTP transport configuration (used when TRANSPORT_MODE=http)
HTTP_HOST=0.0.0.0
HTTP_PORT=3001

# Logging level
# Options: DEBUG | INFO (default) | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
